{
  "type": "module",
  "homepage": "https://minhnguyen-eth.github.io/bigtime-playwright",
  "scripts": {
    "pretest": "rimraf allure-results allure-report",
    "test": "npx playwright test",
    "test:api": "npx playwright test tests/api/",
    "test:ui": "npx playwright test tests/ui/",
    "test:combined": "npx playwright test tests/examples/",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "generate": "node generate-report.js",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "predeploy": "rimraf allure-results",
    "deploy": "node deploy.js",
    "report": "npm run test && npm run generate && npm run deploy"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/node": "^22.15.21",
    "allure-commandline": "^2.34.0",
    "allure-playwright": "^2.15.1",
    "gh-pages": "^6.3.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "mysql2": "^3.14.1",
    "uuid": "^11.1.0"
  }
}